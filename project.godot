; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Blackbanner"
run/main_scene="res://game/scenes/bootstrap/bootstrap.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://game/autoload/event_bus.gd"
GameState="*res://game/autoload/game_state.gd"
SaveManager="*res://game/autoload/save_manager.gd"
RunManager="*res://game/autoload/run_manager.gd"
